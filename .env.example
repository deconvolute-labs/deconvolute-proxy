# Required
GITHUB_TOKEN=ghp_your_pat_here

# Optional — where the SDK writes deconvolute_state.db
# Defaults to ~/.cache/deconvolute/ if not set
DECONVOLUTE_CACHE_DIR=./data/

# Optional — server bind address and port
HOST=127.0.0.1
PORT=8000

# Optional — identifies this proxy instance and with it the connected agent in the audit log and platform
# AGENT_ID=some_id
